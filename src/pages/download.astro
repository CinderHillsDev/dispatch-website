---
// Downloads page. Dispatch is free and open source (Apache-2.0) - the landing and the docs
// link here. Matches the landing's ink + amber theme.
//
// Update `version` when a new release is cut; the per-platform asset URLs are built from it.
const version = '0.7.0';
const releaseBase = `https://github.com/CinderHillsDev/dispatch-platform/releases/download/v${version}`;
const dockerImage = `ghcr.io/cinderhillsdev/dispatch-platform:${version}`;

const platforms = [
  {
    name: 'Windows',
    body: 'One-click installer (WiX bundle) that registers Dispatch as a Windows Service. No database server to install - it uses a bundled SQLite file by default.',
    href: `${releaseBase}/DispatchSetup-${version}-x64.exe`,
    label: `DispatchSetup-${version}-x64.exe`,
  },
  {
    name: 'Linux',
    body: 'Self-contained tarball (x64 + arm64); install.sh sets up a systemd unit. Uses a bundled SQLite file by default - no database server required.',
    href: `${releaseBase}/dispatch-${version}-linux.tar.gz`,
    label: `dispatch-${version}-linux.tar.gz`,
  },
  {
    name: 'Docker',
    body: 'Multi-arch image. Uses bundled SQLite by default, or point it at a PostgreSQL, MariaDB/MySQL or SQL Server you already run.',
    cmd: `docker pull ${dockerImage}`,
  },
  {
    name: 'Azure (one-click)',
    body: 'Spin up an Ubuntu VM with Dispatch via an ARM template - no Marketplace account needed.',
    docsHref: 'https://docs.dispatchrelay.app/deployment/azure/',
    docsLabel: 'Azure deployment guide',
  },
  {
    name: 'Virtual appliance',
    body: 'Ready-to-import VM with bundled SQLite - nothing else to configure. Import, power on, done.',
    downloads: [
      { label: 'Hyper-V (VHDX)', href: `${releaseBase}/dispatch-appliance-${version}-hyperv.vhdx.gz` },
      { label: 'VMware (OVA)', href: `${releaseBase}/dispatch-appliance-${version}-vmware.ova` },
      { label: 'KVM / Proxmox (qcow2)', href: `${releaseBase}/dispatch-appliance-${version}-kvm.qcow2` },
    ],
    docsHref: 'https://docs.dispatchrelay.app/deployment/appliance/',
    docsLabel: 'Appliance guide',
  },
];
// Self-hosted fonts (bundled - no Google request).
import '@fontsource/inter/400.css';
import '@fontsource/inter/500.css';
import '@fontsource/inter/600.css';
import '@fontsource/space-grotesk/600.css';
import '@fontsource/space-grotesk/700.css';
import '../styles/global.css';
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Download Dispatch</title>
    <meta name="description" content="Download Dispatch - the self-hosted email relay - for Windows, Linux, Docker, or as a virtual appliance." />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body class="bg-ink text-paper font-sans antialiased selection:bg-amber/30">
    <div class="mx-auto max-w-5xl px-6">
      <nav class="flex items-center justify-between py-5">
        <a href="/" class="flex items-center gap-2 font-display text-lg font-bold">
          <span class="inline-block h-2.5 w-2.5 rounded-full bg-amber"></span> Dispatch
        </a>
        <div class="flex items-center gap-6 text-sm text-muted">
          <a href="https://docs.dispatchrelay.app/" class="hover:text-paper transition">Docs</a>
          <a href="https://github.com/CinderHillsDev/dispatch-platform" class="hover:text-paper transition">GitHub</a>
          <a href="/" class="hover:text-paper transition">Home</a>
        </div>
      </nav>

      <header class="border-b border-line py-16">
        <p class="font-display text-xs font-semibold uppercase tracking-[0.2em] text-amber">Download · v{version}</p>
        <h1 class="mt-4 font-display text-4xl font-bold tracking-tight sm:text-5xl">Run Dispatch on your own infrastructure</h1>
        <p class="mt-5 max-w-xl text-lg leading-relaxed text-muted">
          Dispatch is free and open source (Apache-2.0). Grab a build below, pull the Docker image, or run an
          installer — then follow the Quickstart to get going.
        </p>
        <div class="mt-8 flex flex-wrap items-center gap-4">
          <a href={`https://github.com/CinderHillsDev/dispatch-platform/releases/tag/v${version}`} class="rounded-md bg-amber px-5 py-2.5 font-medium text-ink hover:bg-amberdim transition">Release notes &amp; all assets</a>
          <span class="text-sm text-muted"><a class="text-amber hover:text-amberdim" href="https://docs.dispatchrelay.app/start/quickstart/">Read the Quickstart</a></span>
        </div>
        <p class="mt-5 text-sm text-muted">
          On 0.5? Upgrade straight to 0.7 - it makes bundled SQLite the default, so there is no database
          server to install. (0.6 was an internal development build and was never released publicly.)
        </p>
      </header>

      <section class="py-14">
        <div class="grid gap-4 sm:grid-cols-2">
          {
            platforms.map((p) => (
              <div class="flex flex-col rounded-xl border border-line bg-panel p-6">
                <h2 class="font-display text-lg font-semibold">{p.name}</h2>
                <p class="mt-2 flex-1 text-sm leading-relaxed text-muted">{p.body}</p>
                <div class="mt-4">
                  {p.href && (
                    <a href={p.href} class="inline-block rounded-md bg-amber px-4 py-2 text-sm font-medium text-ink hover:bg-amberdim transition">
                      {p.hrefLabel ?? `Download ${p.label}`}
                    </a>
                  )}
                  {p.cmd && (
                    <code class="block overflow-x-auto rounded-md border border-line bg-ink px-3 py-2 text-sm text-paper">{p.cmd}</code>
                  )}
                  {p.downloads && (
                    <div class="flex flex-wrap gap-2">
                      {p.downloads.map((d) => (
                        <a href={d.href} class="inline-block rounded-md bg-amber px-3 py-1.5 text-sm font-medium text-ink hover:bg-amberdim transition">{d.label}</a>
                      ))}
                    </div>
                  )}
                  {p.docsHref && (
                    <a href={p.docsHref} class={`text-sm font-medium text-amber hover:text-amberdim transition ${p.downloads ? 'mt-3 inline-block' : ''}`}>{p.docsLabel} →</a>
                  )}
                </div>
              </div>
            ))
          }
        </div>
        <p class="mt-8 text-sm text-muted">
          Verify downloads against <a class="text-amber hover:text-amberdim" href={`${releaseBase}/SHA256SUMS`}>SHA256SUMS</a>.
          Full install instructions live in the <a class="text-amber hover:text-amberdim" href="https://docs.dispatchrelay.app/deployment/overview/">deployment docs</a>.
        </p>
      </section>

      <footer class="flex items-center justify-between border-t border-line py-8 text-sm text-muted">
        <div class="flex items-center gap-2 font-display"><span class="inline-block h-2 w-2 rounded-full bg-amber"></span> Dispatch</div>
        <p class="text-muted/70">© 2026 CinderHills · Apache-2.0 licensed · open source</p>
      </footer>
    </div>
  </body>
</html>
